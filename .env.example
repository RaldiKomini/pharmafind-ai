# Optional: needed for semantic reranking, grounded synthesis, and agent mode.
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Recommended identification and higher-rate access for NCBI E-utilities.
NCBI_TOOL=pharmafind-ai
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

# Optional: raises openFDA count aggregation limits from 100 to 1,000 terms.
OPENFDA_API_KEY=
